# Application
APP_NAME="DentFlow"
SECRET_KEY="change-me-to-a-secure-random-string-at-least-32-chars"
DEBUG=true
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Database
# Cloud (Supabase/Neon): replace with your connection string, keep +asyncpg prefix
DATABASE_URL="postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"
DATABASE_SSL=true
# Local dev (no SSL): postgresql+asyncpg://postgres:password@localhost:5432/dentflow + DATABASE_SSL=false

# Redis
REDIS_URL="redis://localhost:6379"

# AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
S3_BUCKET_NAME="dentflow-documents"

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
