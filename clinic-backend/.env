# Application
APP_NAME="DentFlow"
SECRET_KEY="change-me-to-a-secure-random-string-at-least-32-chars"
DEBUG=true
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Database
# Port 6543 = Supabase PgBouncer (transaction mode). Dramatically faster than
# direct port 5432 because connections are pre-warmed at Supabase's edge.
# prepared_statement_cache_size=0 is required — PgBouncer transaction mode
# does not support named prepared statements.
DATABASE_URL=postgresql+asyncpg://postgres:%23KKPatel%40213@db.qwknwibgdmtpghdvdrex.supabase.co:6543/postgres
DATABASE_SSL=true
SECRET_KEY=pick-any-long-random-string-here-at-least-32-chars
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis
REDIS_URL="redis://localhost:6379"

# AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
S3_BUCKET_NAME="dentflow-documents"

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
